{
  "name": "jewish-zmanim",
  "version": "1.0.0",
  "description": "Jewish Zmanim",
  "author": "Shmulik Kravitz",
  "license": "MIT",
  "homepage": "https://github.com/Shmulik-Kravitz/jewish-zmanim",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shmulik-Kravitz/jewish-zmanim.git"
  },
  "bugs": {
    "url": "https://github.com/Shmulik-Kravitz/jewish-zmanim/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.cts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn typecheck && yarn lint && yarn format && tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src tests",
    "lint:fix": "biome lint --write src tests",
    "format": "biome format --write src tests",
    "format:check": "biome format src tests",
    "check": "biome check src tests",
    "check:fix": "biome check --write src tests",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "biome check --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.1",
    "bumpp": "^11.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsdown": "^0.21.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "yarn@4.13.0"
}
